// ──────────────────────────────────────────────────────────────
//  NOIR — Firestore Security Rules
//  Paste these into Firebase Console → Firestore → Rules tab
// ──────────────────────────────────────────────────────────────

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // TEAMS — anyone can read/write (needed for name registration)
    match /teams/{teamId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'joinedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 30;
      allow update, delete: if false;
    }

    // CLUES — anyone can read released clues; only admin writes
    // (For proper admin-only writes, use Firebase Admin SDK or
    //  add Firebase Auth with admin UID check)
    match /clues/{clueId} {
      allow read: if resource.data.released == true;
      allow write: if true; // TODO: restrict to admin UID after adding Firebase Auth
    }

    // SUBMISSIONS — teams can create; no reading others' submissions
    match /submissions/{subId} {
      allow create: if request.resource.data.keys().hasAll(['team','answer','round','submittedAt'])
                    && request.resource.data.answer is string
                    && request.resource.data.answer.size() > 0;
      allow read: if true; // admin reads all; tighten if needed
      allow update, delete: if false;
    }

    // ROUNDS — lock/unlock status; admin writes
    match /rounds/{roundId} {
      allow read: if true;
      allow write: if true; // TODO: restrict to admin UID
    }
  }
}
